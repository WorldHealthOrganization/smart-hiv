       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode>
       ] ;
       fhir:value [
         a fhir:Coding ;
         fhir:system [
           fhir:v "http://smart.who.int/hiv/CodeSystem/HIVConcepts"^^xsd:anyURI ;
           fhir:l <http://smart.who.int/hiv/CodeSystem/HIVConcepts>
         ] ;
         fhir:code [ fhir:v "HIV.B.DE116" ] ;
         fhir:display [ fhir:v "HIV-positive" ]
       ]
     ] [
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode>
       ] ;
       fhir:value [
         a fhir:Coding ;
