       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
