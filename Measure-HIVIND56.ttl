           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "// Geographic Region\ndefine \"By Geographic Region Stratifier\":\n    First(Patient.address A where A.use in { 'home' }).state"
         ]
