           fhir:v "/*\n @input: \"On ART\"\n @pseudocode: \"On ART\"=True\n */\ndefine \"On ART\":\n  exists(\n    Elements.\"On ART D.DE38\"\n  )"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
