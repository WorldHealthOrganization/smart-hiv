         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Immediately take action or refer for care if client is showing this sign of a serious illness"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n @output \"Immediately take action or refer for care if client is showing this sign of a serious illness.\"\n */\ndefine \"Immediately take action or refer for care if client is showing this sign of a serious illness\":\n  \"Signs of serious illness age 10 or older\" or \"Signs of serious illness age under 10\""
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
