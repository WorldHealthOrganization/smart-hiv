       fhir:condition ( [
         fhir:kind [ fhir:v "applicability" ] ;
         fhir:expression [
           fhir:language [ fhir:v "text/cql-identifier" ] ;
           fhir:expression [ fhir:v "Guidance" ]
         ]
       ] ) ;
       fhir:definition [
         a fhir:Canonical ;
         fhir:v "http://smart.who.int/hiv/ActivityDefinition/HIVGuidanceCommunicationRequestActivity"^^xsd:anyURI ;
         fhir:l <http://smart.who.int/hiv/ActivityDefinition/HIVGuidanceCommunicationRequestActivity>
       ] ;
       fhir:dynamicValue ( [
         fhir:path [ fhir:v "description" ] ;
         fhir:expression [
           fhir:language [ fhir:v "text/cql-identifier" ] ;
           fhir:expression [ fhir:v "Guidance" ]
         ]
       ] )
     ] )
  ] ) . # 

