           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"Signs of serious illness requiring clinical judgement age 10 or older\":\n  \"Age 10 or older\" and exists(\n    Elements.\"Signs of serious illness Observation\" O\n      where\n        O.value ~ Concepts.\"Fever of 39 C or greater\" or\n        O.value ~ Concepts.\"Other sign of serious illness\"\n  )"
         ]
       ] [
