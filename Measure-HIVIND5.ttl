         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n * Other Stratifiers\n */\ndefine hiv_exposure_type:\n  List<String>{\n    if Elements.Exposure_Occupational then 'Occupational' else null,\n    if Elements.Exposure_Non_Occupational_violent then 'Non-occupational violent' else null,\n    if Elements.Exposure_Non_Occupational_consensual_sex then 'Non-occupational consensual sex' else null\n  }"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
