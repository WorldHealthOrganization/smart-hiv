         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "//provider type not provided?\n\ndefine \"Stratification\":\n HIE.\"By Administrative Gender Stratifier\".code \n  + ':' + HIE.\"By Age Stratifier 3\"\n+ ':' + HIE.\"By Geographic Region Stratifier\"\n+ Combine(HIE.patientGroups, ':')\n + ':' + HIE.\"setting\".code\n+ Combine(HIE.prep_product, ':')\n+ Combine(HIE.\"hiv_exposure_type\", ':')"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
