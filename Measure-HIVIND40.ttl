     fhir:parameter ( [
       fhir:name [ fhir:v "Measurement Period" ] ;
       fhir:use [ fhir:v "in" ] ;
       fhir:min [ fhir:v 0 ] ;
       fhir:max [ fhir:v "1" ] ;
