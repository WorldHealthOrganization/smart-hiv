         fhir:value [
           a fhir:String ;
           fhir:v "/*\n @input: Symptoms of TB\n @pseudocode: \"Symptoms of TB\" = 'None'\n */\ndefine \"Does not have symptoms of TB\":\n  exists(\n    Elements.\"Symptoms of TB Observation\" O\n      where O.value ~ Concepts.\"None\"\n  ) or not(\"Has symptoms of TB\")"
         ]
