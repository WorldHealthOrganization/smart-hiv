           fhir:v "C reactive protein test result"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of TB prevention services accepted */\n\n/*\n@dataElement: HIV.D.DE1026 - C reactive protein test result\n@activity: HIV.D4 Screen for TB\n@description: Test result of the client's C reactive protein test result in mg/L\n*/\ndefine \"C reactive protein test result\":\n  Elements.\"C reactive protein test result\" O\n    where O.encounter.references(EncounterId)"
         ]
