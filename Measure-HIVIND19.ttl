           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"Key population member type Observation\":\n  Elements.\"Key population member type Observation\" O\n    where O.effective.toInterval() before end of \"Measurement Period\"\n    or O.issued before end of \"Measurement Period\""
         ]
       ] [
         fhir:url [
