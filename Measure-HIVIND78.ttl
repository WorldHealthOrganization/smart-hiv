           a fhir:String ;
           fhir:v "define \"Other PRV.DE8 date\":\n  [Observation] O\n    where O.status in {'final', 'amended'}\n    and O.code ~ Concepts.\"HIV prevention intervention\"\n    and O.value ~ Concepts.\"Other - HIV.PRV.DE8\"\n  return start of O.effective.toInterval()"
         ]
