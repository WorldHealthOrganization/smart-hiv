         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of Other PRV.DE8 */\n\n/*\n@dataElement: HIV.PRV.DE10 - Date accessed HIV prevention intervention\n@activity: HIV.B6 Capture or update client history\n@description: Date the client accessed HIV prevention intervention\n*/\n// TODO: NSP date requires fix to DeviceUseStatement support\ndefine \"Date accessed HIV prevention intervention\": \n  flatten{\"PrEP service date\", /*\"NSP date\",*/ \"STI services date\", \"VMMC date\", \"Other PRV.DE8 date\",\"OAMT status date\"}"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
