         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"Syndrome/STI diagnosed B.DE226 Condition\":\n  [Condition] C\n    where C.code in Concepts.\"Syndrome/STI diagnosed - HIV.B.DE226 Choices\"\n      and C.verificationStatus.text = 'confirmed'"
