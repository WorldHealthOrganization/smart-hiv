         fhir:value [
           a fhir:String ;
           fhir:v "define \"OAMT status date\":\n  [EpisodeOfCare] EOC\n    where exists(EOC.type T where T ~ Concepts.\"OAMT\")\n    return start of EOC.period"
         ]
