           fhir:v "http://terminology.hl7.org/CodeSystem/condition-clinical"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/condition-clinical>
         ] ;
         fhir:code [ fhir:v "recurrence" ]
       ]
     ] [
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode>
       ] ;
       fhir:value [
         a fhir:Coding ;
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/condition-clinical"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/condition-clinical>
         ] ;
         fhir:code [ fhir:v "relapse" ]
       ]
     ] [
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode>
       ] ;
       fhir:value [
         a fhir:Coding ;
         fhir:system [
           fhir:v "http://smart.who.int/hiv/CodeSystem/HIVConcepts"^^xsd:anyURI ;
           fhir:l <http://smart.who.int/hiv/CodeSystem/HIVConcepts>
         ] ;
         fhir:code [ fhir:v "HIV.C.DE76" ] ;
         fhir:display [ fhir:v "PrEP for HIV prevention" ]
       ]
     ] [
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode>
       ] ;
       fhir:value [
         a fhir:Coding ;
         fhir:system [
           fhir:v "http://smart.who.int/hiv/CodeSystem/HIVConcepts"^^xsd:anyURI ;
           fhir:l <http://smart.who.int/hiv/CodeSystem/HIVConcepts>
         ] ;
         fhir:code [ fhir:v "HIV.B.DE164" ] ;
         fhir:display [ fhir:v "STI testing and treatment services" ]
