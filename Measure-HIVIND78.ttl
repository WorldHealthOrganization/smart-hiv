     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-directReferenceCode>
       ] ;
       fhir:value [
         a fhir:Coding ;
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/condition-clinical"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/condition-clinical>
         ] ;
