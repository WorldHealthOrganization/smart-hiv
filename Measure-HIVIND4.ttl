         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"Measure Population\":\n   Sum(\n    (\n      collapse (HE.\"PREP Prescription\" MR\n      return HIC.\"Prescription Relevant Period\"( MR ) intersect \"Measurement Period\"\n      )\n    ) PREPUseInterval\n      return days between start of PREPUseInterval and end of PREPUseInterval\n  )"
         ]
