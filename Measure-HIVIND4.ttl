           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "prep_product"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define prep_product:\n  List<String>{\n    if \"TDF + FTC C.DE18\" or \"TDF C.DE19\" or \"TDF + 3TC C.DE20\" or \"Other TDF-based regimen\" then 'PREP Product Oral' else null,\n    if \"Dapivirine vaginal ring DVR C.DE22\" then 'PREP Product long-acting device' else null,\n    if \"CAB-LA C.DE23\" then 'PREP Product long-acting injectable' else null\n  }"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 24
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIND4Logic"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Stratification"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "//provider type not provided?\n\ndefine \"Stratification\":\n HIE.\"By Administrative Gender Stratifier\".code \n  + ':' + HIE.\"By Age Stratifier 3\"\n+ ':' + HIE.\"By Geographic Region Stratifier\"\n+ Combine(HIE.patientGroups, ':') \n + ':' + HIE.\"setting\".code\n+ Combine(HIE.prep_product, ':')"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 25
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "PREP Prescription"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"PREP Prescription\":\n  [MedicationRequest] MR\n    where MR.status = 'completed'\n    and MR.intent = 'order'\n    and (MR.medication as CodeableConcept in Concepts.\"PrEP product prescribed Choices\"\n    or MR.medication as CodeableConcept in Concepts.\"Current PrEP regimen Choices\")"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 26
         ]
       ] ) ;
       fhir:url [
