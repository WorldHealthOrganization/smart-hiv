         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of Reason ART stopped H.DE74 */\n\n/*\n@dataElement: HIV.H.DE75 - Toxicity/side effects\n@activity: HIV.H3 Record outreach and result\n@description: Client stopped ART because of toxicity/side effects\n*/\n\ndefine \"Toxicity/side effects H.DE75\":\n  exists([MedicationStatement] MS\n    where MS.status in {'stopped'}\n    and exists(MS.reasonCode C where C ~ Concepts.\"On ART - HIV.H.DE47\")\n    and exists(MS.statusReason R where R ~ Concepts.\"Toxicity/side effects - HIV.H.DE75\")\n    and start of MS.effective.toInterval() during \"Measurement Period\")"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
