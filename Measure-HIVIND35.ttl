         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
