         fhir:value [
           a fhir:String ;
           fhir:v "define \"Methadone D.DE555\":\n  [MedicationRequest] MR\n        where MR.intent = 'order'\n        and MR.medication ~ ConceptsCustom.\"methadone\""
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
