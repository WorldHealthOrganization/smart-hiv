         fhir:value [
           a fhir:String ;
           fhir:v "define function ToDateTime(value dateTime): value.value"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 22
         ]
       ] ) ;
       fhir:url [
