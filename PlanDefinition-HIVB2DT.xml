      <extension url="http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition">
        <extension url="libraryName">
          <valueString value="HIVEncounterElements"/>
        </extension>
        <extension url="name">
          <valueString value="Current Patient Age In Years"/>
        </extension>
        <extension url="statement">
          <valueString value="/**&#xA; * HIV Elements&#xA; */&#xA;&#xA;// Auto-generated Elements from DAK Data Dictionary&#xA;//   Entries based on DAK Data Dictionary for Data Elements marked as used&#xA;//   in at least one Decision Support Table or Aggregate Indicator&#xA;&#xA;/*&#xA;@dataElement: HIV.A.DE17 - Age&#xA;@activity: HIV.A6.1 Review sociodemographic data with client | HIV.A5 Create new client record&#xA;@description: Calculated age (number of years) of the client based on date of birth&#xA;*/&#xA;/** &#xA; * @dataElement Patient age in years&#xA; */&#xA;define &quot;Current Patient Age In Years&quot;:&#xA;  AgeInYearsAt(Today())"/>
        </extension>
        <extension url="displaySequence">
          <valueInteger value="0"/>
        </extension>
      </extension>
      <extension url="http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition">
        <extension url="libraryName">
          <valueString value="HIVB2DTLogic"/>
        </extension>
        <extension url="name">
          <valueString value="Age 10 or older"/>
        </extension>
        <extension url="statement">
          <valueString value="/*&#xA;  @input: &quot;Age&quot;&#xA;  @pseudocode: 'Age' &gt;= 10 years&#xA;  */&#xA;define &quot;Age 10 or older&quot;:&#xA;  Elements.&quot;Current Patient Age In Years&quot; &gt;= 10"/>
        </extension>
        <extension url="displaySequence">
          <valueInteger value="1"/>
        </extension>
      </extension>
      <extension url="http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition">
        <extension url="libraryName">
          <valueString value="HIVElements"/>
        </extension>
        <extension url="name">
          <valueString value="Signs of serious illness Observation"/>
        </extension>
        <extension url="statement">
          <valueString value="define &quot;Signs of serious illness Observation&quot;:&#xA;  [Observation: Concepts.&quot;Signs of serious illness&quot;] O&#xA;    where O.status in { 'final', 'amended', 'corrected' }"/>
        </extension>
        <extension url="displaySequence">
          <valueInteger value="2"/>
        </extension>
      </extension>
      <extension url="http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition">
        <extension url="libraryName">
          <valueString value="HIVEncounterElements"/>
        </extension>
        <extension url="name">
          <valueString value="Signs of serious illness Observation"/>
        </extension>
        <extension url="statement">
          <valueString value="define &quot;Signs of serious illness Observation&quot;:&#xA;  Elements.&quot;Signs of serious illness Observation&quot; O&#xA;    where O.encounter.references(EncounterId)&#xA;      or O.effective.toInterval() starts on or before Today"/>
        </extension>
        <extension url="displaySequence">
          <valueInteger value="3"/>
        </extension>
      </extension>
      <extension url="http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition">
        <extension url="libraryName">
          <valueString value="HIVB2DTLogic"/>
        </extension>
        <extension url="name">
          <valueString value="Immediately take action or refer for care if a client is having this issue"/>
        </extension>
        <extension url="statement">
          <valueString value="/*&#xA; @output: &quot;Immediately take action or refer for care if a client is having this issue&quot;&#xA; */&#xA;define &quot;Immediately take action or refer for care if a client is having this issue&quot;:&#xA;  &quot;Age 10 or older&quot; and exists(&#xA;    Elements.&quot;Signs of serious illness Observation&quot; O&#xA;      where O.value ~ Concepts.&quot;Tachycardia&quot;&#xA;  )"/>
        </extension>
        <extension url="displaySequence">
          <valueInteger value="4"/>
        </extension>
      </extension>
      <extension url="http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition">
        <extension url="libraryName">
          <valueString value="HIVB2DTLogic"/>
        </extension>
        <extension url="name">
          <valueString value="Signs of serious illness age 10 or older"/>
        </extension>
        <extension url="statement">
          <valueString value="/*&#xA; Supporting Logic&#xA;*/&#xA;define &quot;Signs of serious illness age 10 or older&quot;:&#xA;  &quot;Age 10 or older&quot; and exists(&#xA;    Elements.&quot;Signs of serious illness Observation&quot; O&#xA;      where&#xA;        O.value ~ Concepts.&quot;Tachypnea&quot; or&#xA;        O.value ~ Concepts.&quot;Unable to walk unaided&quot;&#xA;  )"/>
        </extension>
        <extension url="displaySequence">
          <valueInteger value="5"/>
        </extension>
      </extension>
      <extension url="http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition">
        <extension url="libraryName">
          <valueString value="HIVB2DTLogic"/>
        </extension>
        <extension url="name">
          <valueString value="Age under 10"/>
        </extension>
        <extension url="statement">
          <valueString value="/*&#xA;  @input: &quot;Age&quot;&#xA;  @pseudocode: 'Age' &lt; 10 years&#xA;  */&#xA;define &quot;Age under 10&quot;:&#xA;  Elements.&quot;Current Patient Age In Years&quot; &lt; 10"/>
        </extension>
        <extension url="displaySequence">
          <valueInteger value="6"/>
        </extension>
      </extension>
      <extension url="http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition">
        <extension url="libraryName">
          <valueString value="HIVB2DTLogic"/>
        </extension>
        <extension url="name">
          <valueString value="Signs of serious illness age under 10"/>
        </extension>
        <extension url="statement">
          <valueString value="define &quot;Signs of serious illness age under 10&quot;:&#xA;  &quot;Age under 10&quot; and exists(&#xA;    Elements.&quot;Signs of serious illness Observation&quot; O&#xA;      where&#xA;        O.value ~ Concepts.&quot;Lethargy - HIV.D.DE22&quot; or&#xA;        O.value ~ Concepts.&quot;Unconsciousness&quot; or&#xA;        O.value ~ Concepts.&quot;Convulsions&quot; or&#xA;        O.value ~ Concepts.&quot;Unable to breastfeed&quot; or&#xA;        O.value ~ Concepts.&quot;Unable to drink&quot; or&#xA;        O.value ~ Concepts.&quot;Repeated vomiting&quot;&#xA;    )"/>
        </extension>
        <extension url="displaySequence">
          <valueInteger value="7"/>
        </extension>
      </extension>
      <extension url="http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition">
        <extension url="libraryName">
          <valueString value="HIVB2DTLogic"/>
        </extension>
