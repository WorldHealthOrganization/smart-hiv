         fhir:value [
           a fhir:String ;
           fhir:v "HIV-negative test result"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of HIV-positive B.DE112 */\n\n/*\n@dataElement: HIV.B.DE113 - HIV-negative\n@activity: HIV.B7 Test for HIV using testing algorithm\n@description: Test result is HIV-negative\n*/\ndefine \"HIV-negative test result\":\n  \"HIV test result Observation\" O\n    where O.value ~ Concepts.\"HIV-negative - HIV.B.DE113\""
         ]
       ] [
