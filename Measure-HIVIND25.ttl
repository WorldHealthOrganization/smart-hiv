         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "First Negative Test within Measurement Period"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"First Negative Test within Measurement Period\":\n  (First(\"Negative Tests within Measurement Period\"))"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 4
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVConfig"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Testing Interval"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"Testing Interval\":\n  3 months"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 5
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Negative Tests after First Negative Test"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"Negative Tests after First Negative Test\":\n  Elements.\"HIV-negative test result\" O\n    // with Elements.\"At elevated risk for HIV acquisition B.DE225\" HIV\n    //   such that O.hasMember.references(HIV)\n    where  O.effective.toInterval() starts after start of \"First Negative Test within Measurement Period\".effective.toInterval()\n      and O.effective.toInterval() starts before (start of \"First Negative Test within Measurement Period\".effective.toInterval() + Config.\"Testing Interval\")\n    sort by start of effective.toInterval()"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 6
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIND25Logic"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Numerator"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/**\n * Numerator\n * \n * Definition: Number of individuals who tested HIV-negative assessed to be at elevated risk for HIV acquisition who had another HIV test within a defined period after previous test.\n * Calculation: COUNT of clients with \"At elevated risk for HIV acquisition\"=True AND with a second \"HIV test date\" within fixed period after \"HIV test date\" in the reporting period with \"HIV test result\"='HIV-negative'\n */\n\ndefine \"Numerator\":\n  exists(HIE.\"Negative Tests after First Negative Test\")"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 7
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIND25Logic"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Denominator"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/**\n * Denominator\n *\n * Definition: Number of people assessed as being at elevated risk for HIV acquisition (includes people requesting/receiving any HIV prevention intervention, people from key populations, people with known risk factors or those assessed as being at risk of HIV acquisition) who received an HIV-negative test result in the reporting period.\n * Calculation: COUNT of clients with \"At elevated risk for HIV acquisition\"=True AND with an \"HIV test date\" in the reporting period with \"HIV test result\"='HIV-negative'\n */\n\ndefine \"Denominator\":\n  exists(HIE.\"Negative Tests within Measurement Period\")"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 8
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIND25Logic"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Initial Population"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* Populations */\n\n/*\n *Initial Population\n */\n\ndefine \"Initial Population\":\n  true"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 9
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "By Administrative Gender Stratifier"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@dataElement: HIV.A.DE18 - Gender\n@activity: HIV.A6.1 Review sociodemographic data with client | HIV.A5 Create new client record\n@description: Gender of the client\n*/\n\n/*\n * By Administrative Gender of Patient Stratifier\n * Need to expand codes\n */\n\ndefine \"By Administrative Gender Stratifier\":\n  case \n      when Patient.gender = 'male' then Concepts.\"Male\"\n      when Patient.gender = 'female' then Concepts.\"Female\"\n      when Patient.gender = 'transgender female' then Concepts.\"Transgender female\"\n      when Patient.gender = 'transgender male' then Concepts.\"Transgender male\"\n      else Concepts.\"Other - HIV.A.DE23\"\n  end"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 10
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Already knew positive"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of HIV status of partner or contact */\n\n/*\n@dataElement: HIV.H.DE35 - Already knew positive\n@activity: HIV.B6 Capture or update client history\n@description: The partner or contact of the index case already knew they are HIV-positive\n*/\n\ndefine \"Already knew positive\":\n  [Observation: Concepts.\"HIV status of partner or contact\"] O \n    where O.status in { 'final', 'amended', 'corrected' }\n    and exists(O.category OC where OC ~ ConceptsCustom.\"social-history\")\n    and O.code ~ Concepts.\"Already knew positive\""
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 11
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Already knew positive"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of Inconclusive G.DE73 */\n\n/*\n@dataElement: HIV.H.DE35 - Already knew positive\n@activity: HIV.B6 Capture or update client history\n@description: The partner or contact of the index case already knew they are HIV-positive\n*/\n\ndefine \"Already knew positive\":\n  exists(Elements.\"Already knew positive\" O where O.issued during \"Measurement Period\")"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 12
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Newly diagnosed"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of Already knew positive */\n\n/*\n@dataElement: HIV.H.DE36 - Newly diagnosed\n@activity: HIV.B6 Capture or update client history\n@description: The partner or contact of the index case is newly diagnosed as HIV-positive\n*/\n\ndefine \"Newly diagnosed\":\n  [Observation: Concepts.\"HIV status of partner or contact\"] O \n    where O.status in { 'final', 'amended', 'corrected' }\n    and exists(O.category OC where OC ~ ConceptsCustom.\"social-history\")\n    and O.code ~ Concepts.\"Newly diagnosed\""
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 13
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Newly diagnosed"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of Already knew positive */\n\n/*\n@dataElement: HIV.H.DE36 - Newly diagnosed\n@activity: HIV.B6 Capture or update client history\n@description: The partner or contact of the index case is newly diagnosed as HIV-positive\n*/\n\ndefine \"Newly diagnosed\":\n  exists(Elements.\"Newly diagnosed\" O where O.issued during \"Measurement Period\")"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 14
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Negative H.DE37"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of Newly diagnosed */\n\n/*\n@dataElement: HIV.H.DE37 - Negative\n@activity: HIV.B6 Capture or update client history\n@description: The partner or contact of the index case is newly diagnosed is HIV-negative\n*/\n\ndefine \"Negative H.DE37\":\n  [Observation: Concepts.\"HIV status of partner or contact\"] O \n    where O.status in { 'final', 'amended', 'corrected' }\n    and exists(O.category OC where OC ~ ConceptsCustom.\"social-history\")\n    and O.code ~ Concepts.\"Negative - HIV.H.DE37\""
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 15
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Negative H.DE37"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of Newly diagnosed */\n\n/*\n@dataElement: HIV.H.DE37 - Negative\n@activity: HIV.B6 Capture or update client history\n@description: The partner or contact of the index case is newly diagnosed is HIV-negative\n*/\n\ndefine \"Negative H.DE37\":\n  exists(Elements.\"Negative H.DE37\" O where O.issued during \"Measurement Period\")"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 16
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIV status of partner or contact"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"HIV status of partner or contact\":\n  case \n      when \"Already knew positive\" then Concepts.\"Already knew positive\"\n      when \"Newly diagnosed\" then Concepts.\"Newly diagnosed\"\n      when \"Negative H.DE37\" then Concepts.\"Negative - HIV.H.DE37\"\n      else null\n  end"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 17
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Age In Years"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/* End of Visit date A.DE3 */\n\n/*\n@dataElement: HIV.A.DE17 - Age\n@activity: HIV.A6.1 Review sociodemographic data with client | HIV.A5 Create new client record\n@description: Calculated age (number of years) of the client based on date of birth\n*/\ndefine \"Age In Years\":\n  AgeInYearsAt(start of \"Measurement Period\")"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 18
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "By Age Stratifier 2"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n * By Age Stratifiers\n * Age (0–4, 5–9, 10–14, 15–19, 20–24, 25–49, 50+ years)\n * \n */\ndefine \"By Age Stratifier 2\":\n  case \n      when \"Age In Years\" <= 4 then '0-4'\n      when \"Age In Years\" <= 9 then '5-9'\n      when \"Age In Years\" <= 14 then '10–14'\n      when \"Age In Years\" <= 19 then '15–19'\n      when \"Age In Years\" <= 24 then '20–24'\n      when \"Age In Years\" <= 49 then '25–49'\n      when \"Age In Years\" >= 50 then '50+'\n      else null\n  end"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 19
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "HIVIndicatorElements"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
