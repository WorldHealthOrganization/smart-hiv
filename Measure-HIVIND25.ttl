         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"Stratification\":\n HIE.\"By Administrative Gender Stratifier\".code \n + ':' + HIE.\"HIV status of partner or contact\".code\n  + ':' + HIE.\"By Age Stratifier 2\"\n+ ':' + HIE.\"By Geographic Region Stratifier\"\n+ Combine(HIE.patientGroups, ':')"
